# Discord Bot
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_id_here
GUILD_ID=your_guild_id_here  # Opcional: para deploy de comandos solo en un servidor

# PandaScore API — rareza asignada por hash del ID del jugador
# Registro: https://pandascore.co
PANDASCORE_API_KEY=

# PostgreSQL — Supabase
# Project Settings → Database → Connection string → URI
DATABASE_URL=

# Prefijo personalizado
# Configurar desde Discord con /configurar prefijo
# IMPORTANTE: Activar "Message Content Intent" en Discord Developer Portal → Bot → Privileged Gateway Intents
